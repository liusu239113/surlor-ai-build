<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Operit" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/orange_500</item>
        <item name="colorPrimaryVariant">@color/orange_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/blue_500</item>
        <item name="colorSecondaryVariant">@color/blue_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/game_surface_dark</item>
        <item name="colorSurface">@color/game_surface</item>
        <!-- Declare support for drawing into the status bar / display cutout area. -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/game_surface_dark</item>
        <!-- Customize your theme here. -->
    </style>
</resources>
